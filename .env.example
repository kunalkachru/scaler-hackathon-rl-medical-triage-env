# Copy to ".env" and fill in values. The real ".env" file is gitignored — never commit secrets.
#
#   cp .env.example .env

# --- Hugging Face (required for python setupCredentials.py) ---
# Admin/write token for the account that owns the Space (Settings → Access Tokens).
HF_TOKEN=

# Space repo id: <username>/<space-name>
SPACE_REPO_ID=

# Token used at runtime for Inference API / router calls (often same as HF_TOKEN).
INFERENCE_HF_TOKEN=

# --- Optional: inference.py / local runs (defaults exist in code) ---
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct
# SERVER_URL=http://localhost:8000

# --- Optional: alternate OpenAI-compatible providers ---
# OPENAI_API_KEY=
# API_KEY=

# --- Optional: Docker / local labels ---
# LOCAL_IMAGE_NAME=
